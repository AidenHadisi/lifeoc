---
// src/components/layout/Header.astro

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/videos", label: "Videos" },
  { href: "/contact", label: "Contact" },
];

const normalizedPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-base/90 backdrop-blur-md border-b border-border-default"
>
  <nav
    class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between gap-4"
  >
    <a href="/" class="hidden sm:flex items-center gap-3 shrink-0">
      <img
        src="/images/logo.png"
        alt="Life Church of Orange"
        class="h-14 w-auto"
      />
    </a>

    <ul class="flex items-center gap-4 sm:gap-8">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "text-xs sm:text-sm font-body font-medium tracking-wide transition-colors duration-150",
                normalizedPath === href
                  ? "text-accent"
                  : "text-text-muted hover:text-text-primary",
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="https://lifeoc.churchcenter.com/giving"
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary shrink-0 text-xs sm:text-sm px-3 sm:px-5 py-2"
    >
      Online Giving
    </a>
  </nav>
</header>
